rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(ownerId) { return signedIn() && request.auth.uid == ownerId; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }

    match /owners/{ownerId} {
      allow read: if true;
      allow create: if isOwner(ownerId);
      allow update: if isOwner(ownerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if signedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /subscriptions/{ownerId} {
      allow read: if isOwner(ownerId) || isAdmin();
      allow write: if isAdmin();
    }

    match /adminUsers/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
